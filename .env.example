# ============================================
# fal.ai API（動画生成 / 中身はKling）
# ============================================
# 取得先: https://fal.ai/dashboard/keys
FAL_KEY=

# 使用モデル（通常は変更不要）
# Proモード（高品質）と Standardモード（安い）で自動切替されます
FAL_MODEL_PRO=fal-ai/kling-video/v2.6/pro/image-to-video
FAL_MODEL_STD=fal-ai/kling-video/v2.1/standard/image-to-video

# ============================================
# OpenAI API（プロンプト最適化）
# ============================================
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# モデル: gpt-4o / gpt-4o-mini / gpt-4.1
OPENAI_MODEL=gpt-4o

# ============================================
# 簡易ログイン（Basic Auth）
# ============================================
# 社内チームで共有するパスワード（覚えやすいもの。例: vide0-2026-team）
APP_PASSWORD=

# ============================================
# 予算ガードレール
# ============================================
# チーム全体の月次生成上限（本数）。未設定なら無制限。
# 例: 500 → チーム合計で月500本まで。超えると生成ボタンが止まる。
TEAM_MONTHLY_LIMIT=500

# ============================================
# その他
# ============================================
# 暗号化マスターキー（hex 64文字, 必ず変更すること）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=
